enum TrackEventStatusCode {
    UNKNOWN
    INFORMATION_RECEIVED
    AT_PICKUP
    IN_TRANSIT
    OUT_FOR_DELIVERY
    ATTEMPT_FAIL
    DELIVERED
    AVAILABLE_FOR_PICKUP
    EXCEPTION
}

type TrackInfo {
    lastEvent: TrackEvent
}

type TrackEvent {
    status: TrackEventStatus!
    time: DateTime
    description: String
}

type TrackEventStatus {
    code: TrackEventStatusCode!
    name: String
}
